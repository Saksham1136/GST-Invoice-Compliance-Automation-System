# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/gst-compliance

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-at-least-64-chars-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=info

# File Upload
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_BATCH=20
UPLOAD_DIR=./uploads
